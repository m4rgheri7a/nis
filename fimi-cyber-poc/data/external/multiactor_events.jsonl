{"event_id":"gw-test-2021-radioactive-waste","title":"Fabricated radioactive-waste leak story","description":"Compromised news and social-media accounts promoted fabricated statements that radioactive waste had leaked from a Lithuanian nuclear facility and endangered people in Poland. A spoofed government website was used to lend authority to the story.","campaign_id":"ghostwriter_unc1151","campaign_id_source":"curated","reported_actor":"Ghostwriter/UNC1151","target_countries":["Lithuania","Poland"],"target_sectors":["Government","Energy","Media"],"first_seen":"2021-03-17","last_seen":"2021-03-17","ttps":["website compromise","social media account compromise","spoofed government website","fabricated statement","coordinated dissemination"],"channels":["Compromised website","Social media","Impersonation website"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/espionage-group-unc1151-likely-conducts-ghostwriter-influence-activity"],"evidence_ids":["MANDIANT-GW-2021-APPX1"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"gw-test-2021-prostitution","title":"Fabricated military prostitution scandal","description":"Compromised websites and social-media accounts disseminated a fabricated scandal involving Polish, Lithuanian, and United States officials. Spoofed email helped push the planted article to journalists and government recipients.","campaign_id":"ghostwriter_unc1151","campaign_id_source":"curated","reported_actor":"Ghostwriter/UNC1151","target_countries":["Poland","Lithuania","United States"],"target_sectors":["Government","Defence","Media"],"first_seen":"2021-02-25","last_seen":"2021-02-26","ttps":["website compromise","social media account compromise","spoofed email","fabricated article","coordinated dissemination"],"channels":["Compromised website","Social media","Email"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/espionage-group-unc1151-likely-conducts-ghostwriter-influence-activity"],"evidence_ids":["MANDIANT-GW-2021-APPX1"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"dg-ref-2022-media-clones","title":"European news outlet impersonation network","description":"A coordinated network created more than sixty websites that imitated legitimate European news organisations. The sites published fabricated articles about Ukraine and sanctions and were promoted through several social platforms.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["Germany","France","Italy","Ukraine","United Kingdom"],"target_sectors":["Media","Public"],"first_seen":"2022-09-27","last_seen":"2022-09-27","ttps":["media website impersonation","typosquatting","fabricated article","cross-platform amplification","coordinated inauthentic behavior"],"channels":["Impersonation website","Facebook","Instagram","Telegram","Twitter"],"evidence_sources":["https://about.fb.com/news/2022/09/removing-coordinated-inauthentic-behavior-from-china-and-russia/"],"evidence_ids":["META-CIB-2022"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"published"}
{"event_id":"dg-ref-2022-paid-ads","title":"Single-use accounts advertising cloned news sites","description":"Short-lived social-media accounts bought advertisements and posted links that redirected audiences to cloned news websites. Accounts and pages posed as ordinary users while distributing coordinated anti-Ukraine narratives in several languages.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["Germany","France","Italy","United Kingdom"],"target_sectors":["Media","Public"],"first_seen":"2022-09-27","last_seen":"2022-09-27","ttps":["single-use accounts","paid advertisements","media website impersonation","URL redirection","multilingual dissemination"],"channels":["Facebook","Instagram","Impersonation website"],"evidence_sources":["https://about.fb.com/news/2022/09/removing-coordinated-inauthentic-behavior-from-china-and-russia/"],"evidence_ids":["META-CIB-2022"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"published"}
{"event_id":"dg-test-2023-security-tax","title":"Spoofed French foreign-ministry security tax notice","description":"A website impersonating the French foreign ministry announced a fabricated security tax related to support for Ukraine. The page copied government branding and used a lookalike domain before coordinated accounts amplified it.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["France"],"target_sectors":["Government","Public"],"first_seen":"2023-05-29","last_seen":"2023-05-29","ttps":["government website impersonation","typosquatting","fabricated announcement","coordinated amplification"],"channels":["Impersonation website","Social media"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20230719_NP_VIGINUM_RAPPORT-CAMPAGNE-RRN_EN.pdf"],"evidence_ids":["VIGINUM-RRN-2023"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"dg-test-2023-media-clones-fr","title":"French newspaper clone network","description":"Lookalike domains reproduced the visual identity of major French newspapers and hosted fabricated articles. Inauthentic accounts and paid promotion redirected readers to the cloned media pages.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["France"],"target_sectors":["Media","Public"],"first_seen":"2023-06-13","last_seen":"2023-06-13","ttps":["media website impersonation","typosquatting","fabricated article","paid promotion","URL redirection"],"channels":["Impersonation website","Social media","Online advertising"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20230719_NP_VIGINUM_RAPPORT-CAMPAGNE-RRN_EN.pdf"],"evidence_ids":["VIGINUM-RRN-2023"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"dg-test-2023-sanctions","title":"Fabricated reports that sanctions harm Europe","description":"Cloned news sites and a network of inauthentic accounts published stories claiming that sanctions against Russia primarily harmed European citizens. The articles were laundered through imitation media pages and coordinated social distribution.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["France","European Union"],"target_sectors":["Media","Public"],"first_seen":"2023-06-13","last_seen":"2023-06-13","ttps":["media website impersonation","fabricated article","narrative laundering","coordinated inauthentic behavior"],"channels":["Impersonation website","Social media"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20230719_NP_VIGINUM_RAPPORT-CAMPAGNE-RRN_EN.pdf"],"evidence_ids":["VIGINUM-RRN-2023"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"dg-test-2023-russophobia","title":"Western Russophobia narrative through imitation outlets","description":"Fabricated articles accusing Western states of Russophobia appeared on websites masquerading as independent or established media. Coordinated accounts relayed the same links and talking points to European audiences.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["France","European Union"],"target_sectors":["Media","Public"],"first_seen":"2023-06-13","last_seen":"2023-06-13","ttps":["media website impersonation","fabricated article","coordinated amplification","multilingual dissemination"],"channels":["Impersonation website","Social media"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20230719_NP_VIGINUM_RAPPORT-CAMPAGNE-RRN_EN.pdf"],"evidence_ids":["VIGINUM-RRN-2023"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"dg-test-2023-refugees","title":"Ukrainian refugees framed as a burden on Europe","description":"Imitation news websites published fabricated claims that hosting Ukrainian refugees caused severe social and economic harm in European states. False accounts and advertising were used to push the cloned articles.","campaign_id":"doppelganger","campaign_id_source":"curated","reported_actor":"Doppelganger/RRN/Storm 1099","target_countries":["France","European Union"],"target_sectors":["Media","Public"],"first_seen":"2023-06-13","last_seen":"2023-06-13","ttps":["media website impersonation","fabricated article","paid advertisements","coordinated amplification"],"channels":["Impersonation website","Social media","Online advertising"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20230719_NP_VIGINUM_RAPPORT-CAMPAGNE-RRN_EN.pdf"],"evidence_ids":["VIGINUM-RRN-2023"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"db-ref-2022-apt41","title":"Altered reporting falsely recast a cyber group as American","description":"Accounts plagiarised mainstream reporting and replaced selected words to claim that a China-linked cyber group was backed by the United States. The altered articles were then promoted through social media, forums, and blogs in English and Chinese.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["United States","China"],"target_sectors":["Government","Cybersecurity","Public"],"first_seen":"2022-10-26","last_seen":"2022-10-26","ttps":["article plagiarism","content alteration","fabricated cyber attribution","coordinated accounts","multilingual dissemination"],"channels":["Twitter","Forums","Blogs","Social media"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/prc-dragonbridge-influence-elections/"],"evidence_ids":["MANDIANT-DRAGONBRIDGE-2022"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"published"}
{"event_id":"db-ref-2022-intrusion-truth","title":"Impersonation of a cybersecurity research persona","description":"Eight newly created accounts copied the profile image, display name, usernames, and earlier posts of a cybersecurity research persona. The accounts later promoted coordinated cyber narratives and shared campaign hashtags.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["United States","China"],"target_sectors":["Cybersecurity","Media"],"first_seen":"2022-09-01","last_seen":"2022-10-26","ttps":["persona impersonation","batch account creation","profile image reuse","post plagiarism","hashtag amplification"],"channels":["Twitter","Social media"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/prc-dragonbridge-influence-elections/"],"evidence_ids":["MANDIANT-DRAGONBRIDGE-2022"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"observed"}
{"event_id":"db-test-2024-guo","title":"Smear narratives placed on inauthentic news sites","description":"Content attacking an exiled Chinese businessman appeared on commercial networks of websites posing as independent local news outlets. The pages mixed copied local reporting with commissioned political material and press releases.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["China","United States"],"target_sectors":["Media","Diaspora"],"first_seen":"2024-11-22","last_seen":"2024-11-22","ttps":["inauthentic local news sites","ad hominem attack","content syndication","commercial PR distribution"],"channels":["Inauthentic news website","Newswire"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/glassbridge-pro-prc-influence-operations"],"evidence_ids":["MANDIANT-GLASSBRIDGE-2024"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"db-test-2024-lai","title":"Taiwan election narratives syndicated before voting","description":"Political narratives targeting a presidential candidate were placed on networks of inauthentic news sites before Taiwan's election. The sites presented themselves as independent outlets and republished aligned material across multiple domains.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["Taiwan"],"target_sectors":["Elections","Media","Public"],"first_seen":"2024-01-13","last_seen":"2024-01-13","ttps":["inauthentic local news sites","election targeting","content syndication","cross-domain amplification"],"channels":["Inauthentic news website","Newswire"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/glassbridge-pro-prc-influence-operations"],"evidence_ids":["MANDIANT-GLASSBRIDGE-2024"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"db-test-2024-tsai","title":"Secret-history smear published by imitation outlets","description":"A secret-history style attack on Taiwan's president was published by a commercial network of websites masquerading as independent media. The network blended ordinary local content with coordinated political narratives.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["Taiwan"],"target_sectors":["Government","Media","Public"],"first_seen":"2024-11-22","last_seen":"2024-11-22","ttps":["inauthentic local news sites","ad hominem attack","content syndication","editorial concealment"],"channels":["Inauthentic news website","Newswire"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/glassbridge-pro-prc-influence-operations"],"evidence_ids":["MANDIANT-GLASSBRIDGE-2024"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"db-test-2024-boston-journal","title":"Coordinated material on a false local Boston outlet","description":"Coordinated political content appeared on a site presenting itself as a local Boston news outlet. The operator ran more than one hundred country- and city-themed domains and used a press-release service to distribute aligned material.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["United States"],"target_sectors":["Media","Public"],"first_seen":"2024-11-22","last_seen":"2024-11-22","ttps":["inauthentic local news sites","commercial PR distribution","content syndication","localized content copying"],"channels":["Inauthentic news website","Newswire"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/glassbridge-pro-prc-influence-operations"],"evidence_ids":["MANDIANT-GLASSBRIDGE-2024"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"db-test-2024-newswire-network","title":"Political content distributed through commercial newswire networks","description":"Marketing firms operating hundreds of undisclosed imitation news sites distributed thematically aligned political content alongside copied local reporting. Shared newswire services and bulk-created domains enabled multilingual placement across many countries.","campaign_id":"spamouflage_dragonbridge","campaign_id_source":"curated","reported_actor":"Spamouflage/Dragonbridge/Storm 1376","target_countries":["Global"],"target_sectors":["Media","Public"],"first_seen":"2024-11-22","last_seen":"2024-11-22","ttps":["bulk domain creation","inauthentic local news sites","commercial PR distribution","multilingual dissemination","content syndication"],"channels":["Inauthentic news website","Newswire"],"evidence_sources":["https://cloud.google.com/blog/topics/threat-intelligence/glassbridge-pro-prc-influence-operations"],"evidence_ids":["MANDIANT-GLASSBRIDGE-2024"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"published"}
{"event_id":"s1516-ref-2024-whistleblower","title":"Staged whistleblower video laundered through covert media","description":"A purported whistleblower delivered a fabricated allegation in a purpose-built video. The video first appeared on a disposable social account, moved to a covert news website, and was then amplified by aligned expatriate and media channels.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["United States","Ukraine"],"target_sectors":["Elections","Media","Public"],"first_seen":"2024-04-17","last_seen":"2024-04-17","ttps":["staged whistleblower","fabricated video","disposable account","covert news website","multi-stage laundering"],"channels":["Social media","Covert news website","Video platform"],"evidence_sources":["https://blogs.microsoft.com/on-the-issues/2024/04/17/russia-us-election-interference-deepfakes-ai/"],"evidence_ids":["MICROSOFT-MTAC-2024"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"published"}
{"event_id":"s1516-ref-2024-trump-effigy","title":"Staged video of soldiers burning a candidate effigy","description":"A fabricated video portrayed Ukrainian soldiers burning an effigy of a United States presidential candidate. The clip used actors and false location cues before being laundered through social accounts and proxy media sites.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["United States","Ukraine"],"target_sectors":["Elections","Defence","Media"],"first_seen":"2024-05-02","last_seen":"2024-05-02","ttps":["staged video","actors","false location cues","disposable account","proxy media amplification"],"channels":["Social media","Video platform","Covert news website"],"evidence_sources":["https://blogs.microsoft.com/on-the-issues/2024/09/18/securing-us-elections-from-nation-state-adversaries/"],"evidence_ids":["MICROSOFT-ELECTIONS-2024"],"source_dataset":"multiactor_external","evaluation_role":"reference","date_basis":"observed"}
{"event_id":"s1516-test-2024-faber","title":"Fabricated claim that a German politician was a Russian agent","description":"A staged testimony accused a German parliamentary defence official of working for Russian intelligence. The allegation was introduced through a purpose-built video and then laundered through a German-language pseudo-media website and social accounts.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["Germany"],"target_sectors":["Government","Defence","Media"],"first_seen":"2024-11-05","last_seen":"2024-11-05","ttps":["staged testimony","fabricated video","pseudo-media website","multi-stage laundering","social amplification"],"channels":["Video platform","Covert news website","Social media"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20250507_TLP-CLEAR_NP_SGDSN_VIGINUM_Technical%20report_Storm-1516.pdf"],"evidence_ids":["VIGINUM-STORM1516-2025"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"s1516-test-2024-army","title":"Fabricated German mass-conscription plan","description":"A fabricated video and article claimed that the German armed forces planned to recruit half a million soldiers. Disposable accounts seeded the claim before pseudo-media sites and aligned channels amplified it.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["Germany"],"target_sectors":["Defence","Government","Public"],"first_seen":"2024-11-19","last_seen":"2024-11-19","ttps":["fabricated video","disposable account","pseudo-media website","multi-stage laundering","coordinated amplification"],"channels":["Video platform","Covert news website","Social media"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20250507_TLP-CLEAR_NP_SGDSN_VIGINUM_Technical%20report_Storm-1516.pdf"],"evidence_ids":["VIGINUM-STORM1516-2025"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"s1516-test-2024-habeck","title":"Staged assault allegation against a German minister","description":"A person presented as a witness made a fabricated assault allegation against a German minister in a staged video. The clip was seeded by an ephemeral account, republished by a pseudo-news site, and amplified by established influence channels.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["Germany"],"target_sectors":["Government","Elections","Media"],"first_seen":"2024-12-06","last_seen":"2024-12-06","ttps":["staged witness","fabricated video","ephemeral account","pseudo-media website","multi-stage laundering"],"channels":["Video platform","Social media","Covert news website"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20250507_TLP-CLEAR_NP_SGDSN_VIGINUM_Technical%20report_Storm-1516.pdf"],"evidence_ids":["VIGINUM-STORM1516-2025"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"s1516-test-2025-merz","title":"Fabricated mental-health allegation against an election candidate","description":"A staged medical-style testimony alleged that a German election candidate had serious mental-health problems. A disposable account posted the video, after which a pseudo-media article and coordinated accounts broadened distribution.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["Germany"],"target_sectors":["Elections","Government","Media"],"first_seen":"2025-02-03","last_seen":"2025-02-03","ttps":["staged testimony","fabricated video","disposable account","pseudo-media website","coordinated amplification"],"channels":["Video platform","Social media","Covert news website"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20250507_TLP-CLEAR_NP_SGDSN_VIGINUM_Technical%20report_Storm-1516.pdf"],"evidence_ids":["VIGINUM-STORM1516-2025"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
{"event_id":"s1516-test-2025-afd-ballots","title":"Fabricated destruction of election ballots","description":"A staged video claimed that postal ballots for a German political party were being destroyed before the federal election. The clip emerged from a disposable persona and was relayed through pseudo-media and coordinated amplification accounts.","campaign_id":"storm_1516","campaign_id_source":"curated","reported_actor":"Storm-1516/Neva Flood","target_countries":["Germany"],"target_sectors":["Elections","Government","Public"],"first_seen":"2025-02-20","last_seen":"2025-02-20","ttps":["staged video","election interference narrative","disposable persona","pseudo-media website","multi-stage laundering"],"channels":["Video platform","Social media","Covert news website"],"evidence_sources":["https://www.sgdsn.gouv.fr/files/files/Publications/20250507_TLP-CLEAR_NP_SGDSN_VIGINUM_Technical%20report_Storm-1516.pdf"],"evidence_ids":["VIGINUM-STORM1516-2025"],"source_dataset":"multiactor_external","evaluation_role":"holdout","date_basis":"observed"}
